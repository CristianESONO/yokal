# Yokalma Environment Variables
# Copiez ce fichier en .env et configurez les valeurs pour votre environnement

# ─────────────────────────────────────────────
# Django Core
# ─────────────────────────────────────────────
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=False
ALLOWED_HOSTS=yokalma.com,www.yokalma.com

# ─────────────────────────────────────────────
# Database (MySQL Production)
# ─────────────────────────────────────────────
DATABASE_NAME=yokalma_db
DATABASE_USER=yokalma_user
DATABASE_PASSWORD=your_secure_password
DATABASE_HOST=localhost
DATABASE_PORT=3306

# ─────────────────────────────────────────────
# Email Configuration (SMTP Production)
# ─────────────────────────────────────────────
# Options: django.core.mail.backends.smtp.EmailBackend (production)
#          django.core.mail.backends.console.EmailBackend (dev)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# SMTP Server Configuration (Exemple: Gmail, SendGrid, Mailgun, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# Email From
DEFAULT_FROM_EMAIL=noreply@yokalma.com
SERVER_EMAIL=noreply@yokalma.com

# ─────────────────────────────────────────────
# Site Configuration
# ─────────────────────────────────────────────
SITE_URL=https://yokalma.com

# ─────────────────────────────────────────────
# Google Wallet Configuration
# ─────────────────────────────────────────────
GOOGLE_WALLET_ISSUER_ID=your_issuer_id
GOOGLE_SERVICE_ACCOUNT_FILE=path/to/service-account.json
GOOGLE_WALLET_CLASS_PREFIX=yokal_loyalty
DEFAULT_WALLET_LOGO_URL=https://yokalma.com/static/img/logo.png

# ─────────────────────────────────────────────
# Apple Wallet (PassKit) Configuration
# ─────────────────────────────────────────────
APPLE_PASS_TYPE_ID=pass.com.yourcompany.yokalma
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_CERTIFICATE_PATH=path/to/apple_certificate.p12
APPLE_CERTIFICATE_PASSWORD=your_cert_password
APPLE_WWDR_CERT_PATH=path/to/AppleWWDRCA.cer

# ─────────────────────────────────────────────
# Evolution API (WhatsApp Gateway)
# ─────────────────────────────────────────────
EVOLUTION_API_URL=https://your-evolution-api.com
EVOLUTION_API_KEY=your_api_key

# ─────────────────────────────────────────────
# PayTech (Paiements abonnements)
# ─────────────────────────────────────────────
PAYTECH_API_KEY=your_paytech_api_key
PAYTECH_API_SECRET=your_paytech_api_secret
PAYTECH_BASE_URL=https://paytech.sn/api
PAYTECH_ENV=prod

# ─────────────────────────────────────────────
# Exchange Rate API (Optionnel)
# ─────────────────────────────────────────────
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key
